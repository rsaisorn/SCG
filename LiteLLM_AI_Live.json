                    "spec": {
                      "editorType": "sql",
                      "format": 0,
                      "pluginVersion": "4.18.0",
                      "queryType": "timeseries",
                      "rawSql": "SELECT\n  toStartOfInterval(startTime, INTERVAL 30 MINUTE) AS time,\n  sum(spend) AS Today\nFROM \"litellm_prod\".\"LiteLLM_SpendLogs\"\nWHERE startTime >= $__fromTime\n  AND startTime <= $__toTime\nGROUP BY time\nORDER BY time ASC"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              },
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "ffpvnlvixskjke"
                    },
                    "group": "grafana-clickhouse-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "editorType": "sql",
                      "format": 0,
                      "pluginVersion": "4.18.0",
                      "queryType": "timeseries",
                      "rawSql": "SELECT\n  toStartOfInterval(\n    startTime + INTERVAL 1 DAY, INTERVAL 30 MINUTE\n  ) AS time,\n  sum(spend) AS Yesterday\nFROM \"litellm_prod\".\"LiteLLM_SpendLogs\"\nWHERE startTime >= $__fromTime - INTERVAL 1 DAY\n  AND startTime <= $__toTime   - INTERVAL 1 DAY\nGROUP BY time\nORDER BY time ASC"
                    },
                    "version": "v0"
                  },
                  "refId": "B"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
