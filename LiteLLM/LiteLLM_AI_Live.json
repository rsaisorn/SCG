    "panel-8": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "ffpvnlvixskjke"
                    },
                    "group": "grafana-clickhouse-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "editorType": "sql",
                      "format": 1,
                      "pluginVersion": "4.18.0",
                      "queryType": "table",
                      "rawSql": "SELECT\n  formatDateTime(bucket_local, '%H:%i') AS time_label,\n  request_count\nFROM\n(\n  SELECT\n    toStartOfHour(startTime + INTERVAL 7 HOUR) AS bucket_local,\n    count(*) AS request_count\n  FROM \"litellm_prod\".\"monitor_spendlogs\"\n  WHERE startTime >= $__fromTime\n    AND startTime <= $__toTime\n  GROUP BY bucket_local\n  ORDER BY bucket_local ASC\n  WITH FILL\n    FROM toStartOfHour($__fromTime + INTERVAL 7 HOUR)\n    TO toStartOfHour($__toTime + INTERVAL 7 HOUR)\n    STEP INTERVAL 1 HOUR\n)"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
        "description": "Number of AI requests per 1 hour window today. Peaks indicate busy usage periods across the team.\n",
