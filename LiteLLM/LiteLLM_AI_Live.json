            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "ffpvnlvixskjke"
                    },
                    "group": "grafana-clickhouse-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "editorType": "sql",
                      "format": 1,
                      "pluginVersion": "4.18.0",
                      "queryType": "table",
                      "rawSql": "SELECT\n  replaceRegexpOne(model, '^.*/', '') AS model_name,\n  sum(spend) AS total_spend\nFROM \"litellm_prod\".\"monitor_spendlogs\"\nWHERE startTime >= $__fromTime\n  AND startTime <= $__toTime\n  AND model IS NOT NULL\n  AND model != ''\nGROUP BY model_name\nORDER BY total_spend DESC\nLIMIT 10"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
