    "panel-7": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "ffpvnlvixskjke"
                    },
                    "group": "grafana-clickhouse-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "editorType": "sql",
                      "format": 0,
                      "pluginVersion": "4.18.0",
                      "queryType": "timeseries",
                      "rawSql": "SELECT\n  time,\n  sum(period_spend) OVER (ORDER BY time ASC) AS Today\nFROM\n(\n  SELECT\n    toStartOfInterval(startTime, INTERVAL 30 MINUTE) AS time,\n    sum(spend) AS period_spend\n  FROM \"litellm_prod\".\"monitor_spendlogs\"\n  WHERE startTime >= $__fromTime\n    AND startTime <= $__toTime\n  GROUP BY time\n)\nORDER BY time ASC"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              },
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "ffpvnlvixskjke"
                    },
                    "group": "grafana-clickhouse-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "editorType": "sql",
                      "format": 0,
                      "pluginVersion": "4.18.0",
                      "queryType": "timeseries",
                      "rawSql": "SELECT\n  time,\n  sum(period_spend) OVER (ORDER BY time ASC) AS Yesterday\nFROM\n(\n  SELECT\n    toStartOfInterval(startTime + INTERVAL 1 DAY, INTERVAL 30 MINUTE) AS time,\n    sum(spend) AS period_spend\n  FROM \"litellm_prod\".\"monitor_spendlogs\"\n  WHERE startTime >= $__fromTime - INTERVAL 1 DAY\n    AND startTime <= $__toTime - INTERVAL 1 DAY\n  GROUP BY time\n)\nORDER BY time ASC"
                    },
                    "version": "v0"
                  },
                  "refId": "B"
                }
              },
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "ffpvnlvixskjke"
                    },
                    "group": "grafana-clickhouse-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "editorType": "sql",
                      "format": 0,
                      "pluginVersion": "4.18.0",
                      "queryType": "timeseries",
                      "rawSql": "SELECT\n  time,\n  sum(period_spend) OVER (ORDER BY time ASC) AS same_day_last_week\nFROM\n(\n  SELECT\n    toStartOfInterval(startTime + INTERVAL 7 DAY, INTERVAL 30 MINUTE) AS time,\n    sum(spend) AS period_spend\n  FROM \"litellm_prod\".\"monitor_spendlogs\"\n  WHERE startTime >= $__fromTime - INTERVAL 7 DAY\n    AND startTime <= $__toTime - INTERVAL 7 DAY\n  GROUP BY time\n)\nORDER BY time ASC"
                    },
                    "version": "v0"
                  },
                  "refId": "C"
                }
              },
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "ffpvnlvixskjke"
                    },
                    "group": "grafana-clickhouse-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "editorType": "sql",
                      "format": 0,
                      "pluginVersion": "4.18.0",
                      "queryType": "timeseries",
                      "rawSql": "WITH $__fromTime AS selected_start\n\nSELECT\n  selected_start + toIntervalMinute(bucket_index * 30) AS time,\n  avg(running_spend) AS Seven_Day_Average\nFROM\n(\n  SELECT\n    d.day_offset AS day_offset,\n    b.bucket_index AS bucket_index,\n    sum(ifNull(s.period_spend, 0)) OVER (\n      PARTITION BY d.day_offset\n      ORDER BY b.bucket_index ASC\n      ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW\n    ) AS running_spend\n  FROM\n  (\n    SELECT\n      toInt64(number + 1) AS day_offset\n    FROM numbers(7)\n  ) AS d\n  CROSS JOIN\n  (\n    SELECT\n      toInt64(number) AS bucket_index\n    FROM numbers(48)\n  ) AS b\n  LEFT JOIN\n  (\n    SELECT\n      day_offset,\n      bucket_index,\n      sum(spend) AS period_spend\n    FROM\n    (\n      SELECT\n        startTime,\n        spend,\n        toInt64(intDiv(dateDiff('minute', startTime, selected_start), 1440) + 1) AS day_offset,\n        toInt64(\n          intDiv(\n            dateDiff(\n              'minute',\n              selected_start - toIntervalDay(toInt64(intDiv(dateDiff('minute', startTime, selected_start), 1440) + 1)),\n              startTime\n            ),\n            30\n          )\n        ) AS bucket_index\n      FROM \"litellm_prod\".\"monitor_spendlogs\"\n      WHERE startTime >= selected_start - INTERVAL 7 DAY\n        AND startTime < selected_start\n    )\n    WHERE day_offset >= 1\n      AND day_offset <= 7\n      AND bucket_index >= 0\n      AND bucket_index < 48\n    GROUP BY day_offset, bucket_index\n  ) AS s\n    ON d.day_offset = s.day_offset\n   AND b.bucket_index = s.bucket_index\n)\nGROUP BY bucket_index\nORDER BY time ASC"
                    },
                    "version": "v0"
                  },
                  "refId": "D"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
        "description": "Cumulative AI spend throughout the selected day. Each line adds 30-minute spend into a running total, comparing the selected day with the previous day, the same day last week, and the average running total from the past 7 days.",
        "id": 7,
        "links": [],
        "title": "📈 Running Total Spend Comparison",
        "vizConfig": {
          "group": "timeseries",
          "kind": "VizConfig",
          "spec": {
            "fieldConfig": {
              "defaults": {
                "color": {
                  "mode": "palette-classic"
                },
                "custom": {
